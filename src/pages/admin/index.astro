---
import '../../styles/admin.css';
import UploadField from '../../components/UploadField.astro';
import {
  getProfile, getExperiences, getSkills, getCertifications, getProjects,
  type Profile, type Experience, type Skill, type Certification, type Project,
} from '../../lib/db';

export const prerender = false;

const session = Astro.locals.session;

let dbError: string | null = null;
let profile: Profile | null = null;
let experiences: Experience[] = [];
let skills: Skill[] = [];
let certifications: Certification[] = [];
let projects: Project[] = [];

try {
  [profile, experiences, skills, certifications, projects] = await Promise.all([
    getProfile(), getExperiences(), getSkills(), getCertifications(), getProjects(),
  ]);
} catch (e) {
  dbError = e instanceof Error ? e.message : String(e);
}

const nl = (arr: string[] | undefined) => (arr || []).join('\n');
const p = profile;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Panel · Portafolio</title>
</head>
<body>
  <div class="admin-wrap">
    <div class="admin-top">
      <h1>Panel de administración</h1>
      <div class="admin-user">
        {session?.avatar && <img src={session.avatar} alt={session.login} />}
        <span>@{session?.login}</span>
        <form method="POST" action="/api/auth/logout"><button class="btn btn-ghost" type="submit">Salir</button></form>
      </div>
    </div>

    {dbError && (
      <div class="alert">
        <strong>No se pudo conectar a la base de datos.</strong> Verifica que <code>DATABASE_URL</code> esté
        configurado y que hayas ejecutado el esquema (<code>db/schema.sql</code>) y el seed (<code>node db/seed.mjs</code>).
        <br />Detalle: {dbError}
      </div>
    )}

    <nav class="admin-nav">
      <a href="#perfil">Perfil</a>
      <a href="#experiencia">Experiencia</a>
      <a href="#habilidades">Habilidades</a>
      <a href="#certificaciones">Certificaciones</a>
      <a href="#proyectos">Proyectos</a>
      <a href="/" target="_blank">Ver sitio ↗</a>
    </nav>

    <!-- ===== PERFIL ===== -->
    <section class="admin-section" id="perfil">
      <h2>Perfil</h2>
      <p class="hint">Datos de la cabecera y la sección de contacto.</p>
      <form class="card entity" method="POST" action="/api/admin/profile">
        <div class="row">
          <label>Nombre<input name="name" value={p?.name ?? ''} /></label>
          <label>Rol / título<input name="role" value={p?.role ?? ''} /></label>
        </div>
        <label>Resumen profesional<textarea name="summary">{p?.summary ?? ''}</textarea></label>
        <UploadField label="Avatar (imagen)" name="avatar_url" value={p?.avatar_url ?? ''} accept="image/*" placeholder="https://res.cloudinary.com/…" />
        <div class="row">
          <label>Correo<input name="email" value={p?.email ?? ''} /></label>
          <label>URL LinkedIn<input name="linkedin_url" value={p?.linkedin_url ?? ''} /></label>
        </div>
        <div class="row">
          <label>Etiqueta LinkedIn<input name="linkedin_label" value={p?.linkedin_label ?? ''} /></label>
          <label>URL GitHub<input name="github_url" value={p?.github_url ?? ''} /></label>
        </div>
        <label>Etiqueta GitHub<input name="github_label" value={p?.github_label ?? ''} /></label>
        <div class="actions"><button class="btn btn-primary" type="submit">Guardar perfil</button></div>
      </form>
    </section>

    <!-- ===== EXPERIENCIA ===== -->
    <section class="admin-section" id="experiencia">
      <h2>Experiencia laboral</h2>
      <p class="hint">Cada entrada es una tarjeta de la línea de tiempo. "Tareas" y "Etiquetas": una por línea.</p>
      {experiences.map((e) => (
        <details class="card">
          <summary>{e.role || '(sin título)'} <span class="meta">{e.company} · orden {e.sort_order}</span></summary>
          <form class="entity" method="POST" action="/api/admin/experience">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="id" value={e.id} />
            <div class="row">
              <label>Cargo<input name="role" value={e.role} /></label>
              <label>Empresa<input name="company" value={e.company} /></label>
            </div>
            <div class="row">
              <label>Ubicación<input name="location" value={e.location} /></label>
              <label>Periodo<input name="period" value={e.period} /></label>
            </div>
            <label>Tareas (una por línea)<textarea name="tasks">{nl(e.tasks)}</textarea></label>
            <label>Etiquetas (una por línea)<textarea name="tags">{nl(e.tags)}</textarea></label>
            <label>Orden<input type="number" name="sort_order" value={e.sort_order} /></label>
            <div class="actions">
              <button class="btn btn-primary" type="submit">Guardar</button>
              <button class="btn btn-danger" type="submit" formaction="/api/admin/experience" name="_action" value="delete"
                onclick="return confirm('¿Eliminar esta experiencia?')">Eliminar</button>
            </div>
          </form>
        </details>
      ))}
      <details class="card">
        <summary>➕ Nueva experiencia</summary>
        <form class="entity" method="POST" action="/api/admin/experience">
          <input type="hidden" name="_action" value="create" />
          <div class="row">
            <label>Cargo<input name="role" /></label>
            <label>Empresa<input name="company" /></label>
          </div>
          <div class="row">
            <label>Ubicación<input name="location" /></label>
            <label>Periodo<input name="period" placeholder="Mes Año — Mes Año" /></label>
          </div>
          <label>Tareas (una por línea)<textarea name="tasks"></textarea></label>
          <label>Etiquetas (una por línea)<textarea name="tags"></textarea></label>
          <label>Orden<input type="number" name="sort_order" value="0" /></label>
          <div class="actions"><button class="btn btn-primary" type="submit">Añadir experiencia</button></div>
        </form>
      </details>
    </section>

    <!-- ===== HABILIDADES ===== -->
    <section class="admin-section" id="habilidades">
      <h2>Habilidades</h2>
      <p class="hint">Categoría: lenguajes / datos / herramientas. Nivel y barra (0-100) son opcionales.</p>
      {skills.map((s) => (
        <details class="card">
          <summary>{s.name || '(sin nombre)'} <span class="meta">{s.category} · orden {s.sort_order}</span></summary>
          <form class="entity" method="POST" action="/api/admin/skill">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="id" value={s.id} />
            <div class="row">
              <label>Nombre<input name="name" value={s.name} /></label>
              <UploadField label="Icono (imagen)" name="icon" value={s.icon} accept="image/*" />
            </div>
            <div class="row">
              <label>Categoría
                <select name="category">
                  <option value="lenguajes" selected={s.category === 'lenguajes'}>Lenguajes</option>
                  <option value="datos" selected={s.category === 'datos'}>Datos</option>
                  <option value="herramientas" selected={s.category === 'herramientas'}>Herramientas</option>
                </select>
              </label>
              <label>Nivel
                <select name="level">
                  <option value="" selected={!s.level}>(sin nivel)</option>
                  <option value="avanzado" selected={s.level === 'avanzado'}>Avanzado</option>
                  <option value="intermedio" selected={s.level === 'intermedio'}>Intermedio</option>
                  <option value="basico" selected={s.level === 'basico'}>Básico</option>
                </select>
              </label>
            </div>
            <div class="row">
              <label>Barra % (vacío = sin barra)<input type="number" name="bar" min="0" max="100" value={s.bar ?? ''} /></label>
              <label>Orden<input type="number" name="sort_order" value={s.sort_order} /></label>
            </div>
            <div class="actions">
              <button class="btn btn-primary" type="submit">Guardar</button>
              <button class="btn btn-danger" type="submit" name="_action" value="delete"
                onclick="return confirm('¿Eliminar esta habilidad?')">Eliminar</button>
            </div>
          </form>
        </details>
      ))}
      <details class="card">
        <summary>➕ Nueva habilidad</summary>
        <form class="entity" method="POST" action="/api/admin/skill">
          <input type="hidden" name="_action" value="create" />
          <div class="row">
            <label>Nombre<input name="name" /></label>
            <UploadField label="Icono (imagen)" name="icon" accept="image/*" />
          </div>
          <div class="row">
            <label>Categoría
              <select name="category">
                <option value="lenguajes">Lenguajes</option>
                <option value="datos">Datos</option>
                <option value="herramientas" selected>Herramientas</option>
              </select>
            </label>
            <label>Nivel
              <select name="level">
                <option value="" selected>(sin nivel)</option>
                <option value="avanzado">Avanzado</option>
                <option value="intermedio">Intermedio</option>
                <option value="basico">Básico</option>
              </select>
            </label>
          </div>
          <div class="row">
            <label>Barra %<input type="number" name="bar" min="0" max="100" /></label>
            <label>Orden<input type="number" name="sort_order" value="0" /></label>
          </div>
          <div class="actions"><button class="btn btn-primary" type="submit">Añadir habilidad</button></div>
        </form>
      </details>
    </section>

    <!-- ===== CERTIFICACIONES ===== -->
    <section class="admin-section" id="certificaciones">
      <h2>Certificaciones</h2>
      <p class="hint">"Descripción": una línea por punto. "mini" es la miniatura; "pdf" es el archivo del certificado.</p>
      {certifications.map((c) => (
        <details class="card">
          <summary>{c.titulo || '(sin título)'} <span class="meta">orden {c.sort_order}</span></summary>
          <form class="entity" method="POST" action="/api/admin/certification">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="id" value={c.id} />
            <label>Título<input name="titulo" value={c.titulo} /></label>
            <div class="row">
              <UploadField label="Miniatura (imagen)" name="mini" value={c.mini} accept="image/*" />
              <UploadField label="Certificado (PDF)" name="pdf" value={c.pdf} accept=".pdf,application/pdf" />
            </div>
            <label>Resumen<textarea name="resumen">{c.resumen}</textarea></label>
            <label>Descripción (una por línea)<textarea name="descripcion">{nl(c.descripcion)}</textarea></label>
            <label>Orden<input type="number" name="sort_order" value={c.sort_order} /></label>
            <div class="actions">
              <button class="btn btn-primary" type="submit">Guardar</button>
              <button class="btn btn-danger" type="submit" name="_action" value="delete"
                onclick="return confirm('¿Eliminar esta certificación?')">Eliminar</button>
            </div>
          </form>
        </details>
      ))}
      <details class="card">
        <summary>➕ Nueva certificación</summary>
        <form class="entity" method="POST" action="/api/admin/certification">
          <input type="hidden" name="_action" value="create" />
          <label>Título<input name="titulo" /></label>
          <div class="row">
            <UploadField label="Miniatura (imagen)" name="mini" accept="image/*" />
            <UploadField label="Certificado (PDF)" name="pdf" accept=".pdf,application/pdf" />
          </div>
          <label>Resumen<textarea name="resumen"></textarea></label>
          <label>Descripción (una por línea)<textarea name="descripcion"></textarea></label>
          <label>Orden<input type="number" name="sort_order" value="0" /></label>
          <div class="actions"><button class="btn btn-primary" type="submit">Añadir certificación</button></div>
        </form>
      </details>
    </section>

    <!-- ===== PROYECTOS ===== -->
    <section class="admin-section" id="proyectos">
      <h2>Proyectos</h2>
      <p class="hint">"Galería", "Características" y "Tecnologías": una línea por elemento.</p>
      {projects.map((pr) => (
        <details class="card">
          <summary>{pr.title || '(sin título)'} <span class="meta">orden {pr.sort_order}</span></summary>
          <form class="entity" method="POST" action="/api/admin/project">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="id" value={pr.id} />
            <label>Título<input name="title" value={pr.title} /></label>
            <label>Resumen<input name="summary" value={pr.summary} /></label>
            <UploadField label="Portada (imagen)" name="cover" value={pr.cover} accept="image/*" />
            <UploadField label="Galería (una URL por línea; sube para añadir)" name="gallery" value={nl(pr.gallery)} accept="image/*" textarea append />
            <label>Descripción<textarea name="description">{pr.description}</textarea></label>
            <label>Características (una por línea)<textarea name="features">{nl(pr.features)}</textarea></label>
            <label>Tecnologías (una por línea)<textarea name="tech">{nl(pr.tech)}</textarea></label>
            <div class="row">
              <label>URL repositorio<input name="repo" value={pr.repo} /></label>
              <label>URL demo<input name="demo" value={pr.demo} /></label>
            </div>
            <label>Orden<input type="number" name="sort_order" value={pr.sort_order} /></label>
            <div class="actions">
              <button class="btn btn-primary" type="submit">Guardar</button>
              <button class="btn btn-danger" type="submit" name="_action" value="delete"
                onclick="return confirm('¿Eliminar este proyecto?')">Eliminar</button>
            </div>
          </form>
        </details>
      ))}
      <details class="card">
        <summary>➕ Nuevo proyecto</summary>
        <form class="entity" method="POST" action="/api/admin/project">
          <input type="hidden" name="_action" value="create" />
          <label>Título<input name="title" /></label>
          <label>Resumen<input name="summary" /></label>
          <UploadField label="Portada (imagen)" name="cover" accept="image/*" />
          <UploadField label="Galería (una URL por línea; sube para añadir)" name="gallery" accept="image/*" textarea append />
          <label>Descripción<textarea name="description"></textarea></label>
          <label>Características (una por línea)<textarea name="features"></textarea></label>
          <label>Tecnologías (una por línea)<textarea name="tech"></textarea></label>
          <div class="row">
            <label>URL repositorio<input name="repo" /></label>
            <label>URL demo<input name="demo" /></label>
          </div>
          <label>Orden<input type="number" name="sort_order" value="0" /></label>
          <div class="actions"><button class="btn btn-primary" type="submit">Añadir proyecto</button></div>
        </form>
      </details>
    </section>
  </div>

  <script>
    // Subida directa y firmada a Cloudinary desde el panel.
    document.querySelectorAll<HTMLInputElement>('.upload-input').forEach((input) => {
      input.addEventListener('change', async () => {
        const file = input.files?.[0];
        if (!file) return;
        const form = input.closest('form');
        const targetName = input.dataset.target || '';
        const target = form?.querySelector<HTMLInputElement | HTMLTextAreaElement>(`[name="${targetName}"]`);
        const status = input.parentElement?.querySelector('.upload-status') as HTMLElement | null;
        if (!target) return;

        const setStatus = (msg: string, cls = '') => {
          if (status) { status.textContent = msg; status.className = 'upload-status ' + cls; }
        };

        setStatus('Subiendo…');
        try {
          const sign = await fetch('/api/admin/sign-upload').then((r) => r.json());
          if (sign.error) throw new Error(sign.error);

          const fd = new FormData();
          fd.append('file', file);
          fd.append('api_key', sign.apiKey);
          fd.append('timestamp', String(sign.timestamp));
          fd.append('folder', sign.folder);
          fd.append('signature', sign.signature);

          const res = await fetch(`https://api.cloudinary.com/v1_1/${sign.cloudName}/auto/upload`, {
            method: 'POST',
            body: fd,
          });
          const data = await res.json();
          if (!data.secure_url) throw new Error(data.error?.message || 'No se pudo subir el archivo.');

          if (input.dataset.append === 'true') {
            const cur = target.value.trim();
            target.value = (cur ? cur + '\n' : '') + data.secure_url;
          } else {
            target.value = data.secure_url;
          }
          setStatus('✔ Subido', 'ok');
          input.value = '';
        } catch (e) {
          setStatus('✖ ' + (e instanceof Error ? e.message : 'Error'), 'err');
        }
      });
    });
  </script>
</body>
</html>
