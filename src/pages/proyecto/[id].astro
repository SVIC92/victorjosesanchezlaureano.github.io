---
import Layout from "../../layouts/Layout.astro";
import { loadProjects } from "../../lib/content";
import "../../styles/proyectos.css";

export const prerender = false;

const id = parseInt(Astro.params.id ?? "", 10);
const projects = await loadProjects();
const idx = projects.findIndex((p) => p.id === id);

if (idx === -1) {
  return Astro.redirect("/proyectos");
}

const project = projects[idx];
const prevId = projects[(idx - 1 + projects.length) % projects.length].id;
const nextId = projects[(idx + 1) % projects.length].id;
const links = [];
if (project.repo) links.push({ href: project.repo, label: "Código" });
if (project.demo) links.push({ href: project.demo, label: "Demo" });
---
<Layout title={`${project.title} | Victor José Sánchez Laureano`} description={project.summary}>
  <section class="project-viewer">
    <div class="project-header">
      <h2 id="p-title">{project.title}</h2>
      <p id="p-summary" class="muted">{project.summary}</p>
    </div>

    <div class="project-layout">
      <div class="project-left">
        <div class="project-cover">
          <img src={project.cover} alt={project.title} />
        </div>
        <div class="project-gallery" data-title={project.title} data-gallery={JSON.stringify(project.gallery || [])}></div>
      </div>
      <aside class="project-right">
        <div class="desc-card">
          <h3>Descripción</h3>
          <p id="p-desc">{project.description}</p>
          <h4>Características</h4>
          <ul class="project-features">
            {(project.features || []).map((f) => <li>{f}</li>)}
          </ul>
          <h4>Tecnologías</h4>
          <div class="project-tags">
            {(project.tech || []).map((t) => <span class="tag">{t}</span>)}
          </div>
          <div class="project-links" style="margin-top:.6rem;">
            {links.length > 0
              ? links.map((l) => <a class="btn-link" href={l.href} target="_blank" rel="noopener">{l.label}</a>)
              : <span class="muted">Próximamente enlaces</span>}
          </div>
        </div>

        <div class="project-nav">
          <a class="btn-link proj-prev" href={`/proyecto/${prevId}`}>‹ Anterior</a>
          <a class="btn-link proj-next" href={`/proyecto/${nextId}`}>Siguiente ›</a>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  const gal = document.querySelector<HTMLElement>(".project-gallery");
  const cover = document.querySelector<HTMLImageElement>(".project-cover img");

  if (gal && cover) {
    const title = gal.dataset.title || "";
    let gallery: string[] = [];
    try {
      gallery = JSON.parse(gal.dataset.gallery || "[]");
    } catch {
      gallery = [];
    }

    const getPer = () => {
      if (window.matchMedia("(max-width:480px)").matches) return 1;
      if (window.matchMedia("(max-width:768px)").matches) return 2;
      if (window.matchMedia("(max-width:1024px)").matches) return 3;
      return 4;
    };

    function buildGallery() {
      if (!gal || !cover || !gallery.length) {
        if (gal) gal.remove();
        return;
      }
      const per = getPer();
      gal.style.setProperty("--per", String(per));

      const pages: string[][] = [];
      for (let i = 0; i < gallery.length; i += per) {
        pages.push(gallery.slice(i, i + per));
      }

      gal.innerHTML = `
        <button class="pg-arrow prev" aria-label="Anterior">‹</button>
        <div class="pg-viewport">
          <div class="pg-track">
            ${pages.map((page, pi) => `
              <div class="pg-page">
                ${page.map((src, idx) => `
                  <button class="pg-item" data-src="${src}" data-index="${pi * per + idx}" aria-label="Imagen ${pi * per + idx + 1}">
                    <img src="${src}" alt="${title} ${pi * per + idx + 1}">
                  </button>
                `).join("")}
              </div>
            `).join("")}
          </div>
        </div>
        <button class="pg-arrow next" aria-label="Siguiente">›</button>
      `;

      const track = gal.querySelector<HTMLElement>(".pg-track")!;
      const prevBtn = gal.querySelector<HTMLElement>(".pg-arrow.prev")!;
      const nextBtn = gal.querySelector<HTMLElement>(".pg-arrow.next")!;
      let pageIndex = 0;

      const updateArrows = () => {
        prevBtn.classList.toggle("is-disabled", pageIndex <= 0);
        nextBtn.classList.toggle("is-disabled", pageIndex >= pages.length - 1);
      };
      const goToPage = (i: number) => {
        pageIndex = Math.max(0, Math.min(pages.length - 1, i));
        track.style.transform = `translateX(-${pageIndex * 100}%)`;
        updateArrows();
      };
      prevBtn.addEventListener("click", () => goToPage(pageIndex - 1));
      nextBtn.addEventListener("click", () => goToPage(pageIndex + 1));
      updateArrows();

      const items = Array.from(gal.querySelectorAll<HTMLButtonElement>(".pg-item"));
      const setActiveBySrc = (src: string) => {
        items.forEach((b) => b.classList.toggle("is-active", b.dataset.src === src));
      };
      items.forEach((btn) => {
        btn.addEventListener("click", () => {
          const src = btn.dataset.src!;
          cover.style.opacity = "0";
          const onLoad = () => {
            cover.style.opacity = "1";
            cover.removeEventListener("load", onLoad);
          };
          cover.addEventListener("load", onLoad);
          cover.src = src;
          cover.alt = `${title} - vista ${parseInt(btn.dataset.index || "0", 10) + 1}`;
          setActiveBySrc(src);
        });
      });
      setActiveBySrc(cover.getAttribute("src") || "");
    }

    buildGallery();
    let last = getPer();
    window.addEventListener("resize", () => {
      const current = getPer();
      if (current !== last) {
        last = current;
        buildGallery();
      }
    });
  }
</script>
