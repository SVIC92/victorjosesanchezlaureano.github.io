---
import Layout from "../../layouts/Layout.astro";
import { loadCertifications } from "../../lib/content";
import "../../styles/certificacion.css";

export const prerender = false;

const id = parseInt(Astro.params.id ?? "", 10);
const certifications = await loadCertifications();
const len = certifications.length;
const idx = certifications.findIndex((c) => c.id === id);

if (idx === -1) {
  return Astro.redirect("/");
}

const cert = certifications[idx];
const prevId = certifications[(idx - 1 + len) % len].id;
const nextId = certifications[(idx + 1) % len].id;
---
<Layout title={`${cert.titulo} | Certificación`} description={cert.resumen}>
  <div class="cert-viewer">
    <h2 id="cert-title">{cert.titulo}</h2>

    <div class="cert-layout">
      <div class="viewer-pane">
        <iframe id="cert-pdf" src={cert.pdf} title={cert.titulo}></iframe>
      </div>

      <aside class="sidebar-pane">
        <div class="desc-card">
          <h3>Descripción de la certificación</h3>
          <p id="cert-resumen" class="desc-intro">{cert.resumen}</p>
          <div id="cert-desc">
            {Array.isArray(cert.descripcion) && cert.descripcion.length > 0 && (
              <ul class="desc-list">
                {cert.descripcion.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </div>
        </div>
      </aside>
    </div>

    <div class="nav-buttons">
      <a id="prev-cert" href={`/certificacion/${prevId}`}>Anterior</a>
      <a id="next-cert" href={`/certificacion/${nextId}`}>Siguiente</a>
      <a href="/">Volver</a>
    </div>
  </div>
</Layout>
