{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/certification\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/experience\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/profile\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/project\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/skill\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/auth\\/callback\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/auth\\/login\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/auth\\/logout\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/certificacion\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/proyecto\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/proyectos\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}