# Copia este archivo como .env y rellena los valores.
# NUNCA subas el .env real al repositorio (ya está en .gitignore).

# --- Base de datos Neon ---
# En neon.tech > tu proyecto > Connection Details > copia la "Connection string".
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@HOST.neon.tech/DBNAME?sslmode=require"

# --- GitHub OAuth ---
# Crea una OAuth App en https://github.com/settings/developers
#   - Homepage URL:               http://localhost:4321  (y tu dominio en producción)
#   - Authorization callback URL: http://localhost:4321/api/auth/callback
#     (en producción: https://TU-DOMINIO/api/auth/callback)
GITHUB_CLIENT_ID="tu_client_id"
GITHUB_CLIENT_SECRET="tu_client_secret"

# Solo este usuario de GitHub podrá entrar al panel /admin
ALLOWED_GITHUB_LOGIN="SVIC92"

# --- Sesión ---
# Secreto para firmar la cookie de sesión. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="cadena_larga_y_aleatoria"
